# Syria Offers Production Environment
# Copy this to .env and fill in real values

# Database
POSTGRES_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD
DATABASE_URL=postgresql://syriaoffers:CHANGE_THIS_TO_STRONG_PASSWORD@postgres:5432/syriaoffers

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=change-me-to-a-very-long-random-string-at-least-32-characters
DEBUG=false
ALLOWED_HOSTS=91.144.32.230

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Sy2030!!

# Email
MAIL_PASSWORD=your-mail-password-here

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here

# Proxy for Gemini API (optional – needed if your server region is blocked)
# Example: HTTPS_PROXY=http://user:pass@proxyhost:8080
# HTTP_PROXY=http://user:pass@proxyhost:8080
HTTPS_PROXY=
HTTP_PROXY=

# Optional: S3/Storage
# S3_ENDPOINT=...
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...